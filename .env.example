# =============================================================================
#  Single-model API switch.  Copy this file to `.env`, set MODEL_API_KEY + MODEL_NAME,
#  and ONE model does EVERYTHING (optimizer reflection + target rollouts) end-to-end —
#  never split across two providers.  (Resolved by model_config.py.)
#  This package is preconfigured for Qwen — see COMPANY_PROMPT.md.
# =============================================================================

# 1) Provider preset — fills the base URL automatically.
#    qwen = Alibaba DashScope OpenAI-compatible endpoint (dashscope.../compatible-mode/v1).
#    (others: openai | deepseek | moonshot | zhipu | together | openrouter | siliconflow | custom)
MODEL_PROVIDER=qwen

# 2) Your Qwen / DashScope API key.
MODEL_API_KEY=<your Qwen / DashScope API key>

# 3) The Qwen model to evaluate (ask which one your account has enabled).
#    e.g. qwen-plus | qwen-max | qwen-turbo | qwen2.5-72b-instruct
MODEL_NAME=qwen-plus

# -----------------------------------------------------------------------------
# OfficeQA ONLY: its ~788M documents are downloaded from HuggingFace at runtime.
# (LiveMath / SearchQA / SpreadsheetBench data is bundled in the repo — no network.)
HF_TOKEN=<HF_TOKEN_FROM_TEAM_LEAD>
# HF_ENDPOINT=https://hf-mirror.com   # uncomment inside mainland China
# -----------------------------------------------------------------------------

# Optional — only when MODEL_PROVIDER=custom (or to override a preset's URL):
# MODEL_BASE_URL=https://your-host/v1
